# /etc/nginx/sites-available/careersignal
# (Enable with: ln -s /etc/nginx/sites-available/careersignal /etc/nginx/sites-enabled/ )

server {
    listen 80;
    server_name careersignal.de careersignal.app;

    # If you use Let's Encrypt, replace with the usual 80->443 redirect and add a 443 server block.

    location / {
        proxy_pass http://127.0.0.1:8010;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_read_timeout 60s;
    }

    # Optional: cache static files more aggressively
    location /static/ {
        proxy_pass http://127.0.0.1:8010;
        expires 7d;
        add_header Cache-Control "public";
    }
}
